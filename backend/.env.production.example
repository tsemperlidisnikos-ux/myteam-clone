# Production — copy to Railway/Render env vars (never commit real secrets)

DATABASE_URL=postgres://user:pass@host/db?sslmode=require
JWT_SECRET=generate-a-random-string-at-least-32-characters
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://your-app.vercel.app

# Email (required for production invite/reset emails)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.xxxx
SMTP_FROM=noreply@yourclub.gr

# Stripe (optional — Pro subscription)
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_PRICE_ID=price_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
